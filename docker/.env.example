# =============================================================================
# club — Environment Configuration
# =============================================================================
# Copy to .env and fill in required values:  cp .env.example .env
# =============================================================================


# ┌───────────────────────────────────────────────────────────────────────────┐
# │ REQUIRED                                                                  │
# └───────────────────────────────────────────────────────────────────────────┘

# JWT signing secret. MUST be at least 32 characters.
# Generate with:  openssl rand -hex 32
JWT_SECRET=


# ┌───────────────────────────────────────────────────────────────────────────┐
# │ SERVER  (optional)                                                        │
# └───────────────────────────────────────────────────────────────────────────┘

# PORT=10234                       # Host port for docker-compose (NOT the internal port)
# LISTEN_PORT=8080                 # Server listen port inside container (rarely change)
# HOST=0.0.0.0                     # Bind address
# LOG_LEVEL=info                   # debug | info | warning | error


# ┌───────────────────────────────────────────────────────────────────────────┐
# │ DATABASE  (optional — defaults to SQLite)                                 │
# └───────────────────────────────────────────────────────────────────────────┘

# DB_BACKEND=sqlite                # sqlite | postgres
# SQLITE_PATH=/data/db/club.db     # SQLite file path (default)

# ── Uncomment for PostgreSQL ──
# DB_BACKEND=postgres
# POSTGRES_URL=postgres://club:secret@postgres:5432/club


# ┌───────────────────────────────────────────────────────────────────────────┐
# │ STORAGE  (optional — defaults to filesystem)                              │
# └───────────────────────────────────────────────────────────────────────────┘

# BLOB_BACKEND=filesystem          # filesystem | s3
# BLOB_PATH=/data/blobs            # Filesystem storage path (default)

# ── Uncomment for S3-compatible storage ──
# Works with AWS S3, Cloudflare R2, MinIO, DigitalOcean Spaces, Backblaze B2,
# and Firebase Storage / GCS via the S3 interop endpoint.
# BLOB_BACKEND=s3
# S3_BUCKET=club-packages          # required
# S3_REGION=us-east-1              # required (use "auto" for R2, any value for GCS interop)
# S3_ACCESS_KEY=                   # required
# S3_SECRET_KEY=                   # required
# S3_ENDPOINT=                     # required for non-AWS providers; omit for AWS S3
#
# Cloudflare R2 example:
#   S3_REGION=auto
#   S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#
# Firebase Storage / GCS (S3 interop) example:
#   S3_BUCKET=<project-id>.appspot.com
#   S3_REGION=auto
#   S3_ENDPOINT=https://storage.googleapis.com
#   S3_ACCESS_KEY / S3_SECRET_KEY = HMAC key from Cloud Storage Interoperability
#
# MinIO (in-cluster) example:
#   S3_ENDPOINT=http://minio:9000  # http allowed only for localhost / minio service

# ── Uncomment for Firebase Storage / GCS (native) ──
# Recommended for GCP deployments — uses a service-account JSON instead of
# HMAC keys. Presigned download URLs work when credentials include a private
# key (file or inline); under Application Default Credentials the server
# falls back to proxying bytes.
# BLOB_BACKEND=gcs
# GCS_BUCKET=<project-id>.appspot.com         # required; Firebase default bucket
# GCS_CREDENTIALS_FILE=/secrets/sa.json        # path to service-account JSON (preferred)
# GCS_CREDENTIALS_JSON=                        # …or inline JSON (escape newlines in the PEM)
# (unset both to use Application Default Credentials on GCE/GKE/Cloud Run)


# ┌───────────────────────────────────────────────────────────────────────────┐
# │ SEARCH  (optional — defaults to SQLite FTS5)                              │
# └───────────────────────────────────────────────────────────────────────────┘

# SEARCH_BACKEND=sqlite            # sqlite | meilisearch

# ── Uncomment for Meilisearch ──
# SEARCH_BACKEND=meilisearch
# MEILISEARCH_URL=http://meilisearch:7700
# MEILISEARCH_KEY=


# ┌───────────────────────────────────────────────────────────────────────────┐
# │ AUTH  (optional)                                                          │
# └───────────────────────────────────────────────────────────────────────────┘

# SESSION_TTL_HOURS=1              # Web session lifetime
# TOKEN_EXPIRY_DAYS=365            # API token default expiry
# BCRYPT_COST=12                   # Password hashing cost (10–14)

# Self-signup. Off by default (closed registry — invite-only). When true,
# exposes /signup and POST /api/auth/signup. New signups get the
# "editor" role so they can publish packages immediately.
# SIGNUP_ENABLED=false


# ┌───────────────────────────────────────────────────────────────────────────┐
# │ UPLOAD  (optional)                                                        │
# └───────────────────────────────────────────────────────────────────────────┘

# MAX_UPLOAD_BYTES=104857600       # Max tarball size (default: 100 MB)
# TEMP_DIR=/data/tmp/uploads       # Temp dir for in-flight uploads (default)
# SDK_BASE_DIR=/data/cache/sdks    # Dart/Flutter SDKs for pana (default)
# LOGS_DIR=/data/logs              # Log directory (default)


# ┌───────────────────────────────────────────────────────────────────────────┐
# │ DARTDOC  (optional)                                                       │
# └───────────────────────────────────────────────────────────────────────────┘
#
# Dartdoc is only generated for the LATEST version of each package. Two
# serve backends are available:
#   - filesystem (default): local HTML tree at DARTDOC_PATH, served by
#     shelf_static. Requires a persistent /data volume; fine for single-
#     container deployments.
#   - blob: packs each package's dartdoc into an indexed blob inside the
#     BlobStore (works with S3/GCS). Required for multi-replica or
#     ephemeral-container setups (Cloud Run, scale-to-zero, etc.).
#
# Full spec: https://docs.club.birju.dev/reference/dartdoc-serving/

# DARTDOC_BACKEND=filesystem       # filesystem | blob
# DARTDOC_PATH=/data/cache/dartdoc # Output directory when filesystem (default)
# DARTDOC_CACHE_MAX_MEMORY_MB=64   # In-process LRU cap when blob (default)


# ┌───────────────────────────────────────────────────────────────────────────┐
# │ PACKAGE LIFECYCLE  (optional)                                             │
# └───────────────────────────────────────────────────────────────────────────┘

# Enforce the pub spec's 7-day retraction/restoration windows. When true
# (the default), a version can only be retracted within 7 days of publish
# and restored within 7 days of retraction — matches pub.dev behaviour.
# Set to false on a private registry where admins need to retract older
# versions (e.g. pulling a release with a known security issue).
# ENFORCE_RETRACTION_WINDOW=true



# ┌───────────────────────────────────────────────────────────────────────────┐
# │ POSTGRESQL SERVICE  (only for docker-compose.postgres.yml)                │
# └───────────────────────────────────────────────────────────────────────────┘

# POSTGRES_DB=club
# POSTGRES_USER=club
# POSTGRES_PASSWORD=
