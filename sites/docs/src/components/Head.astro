---
// Head override — inject a per-page og:image that matches the PNG
// generated by `npm run render:og` for this route.
//
// Mapping: URL /getting-started/installation/ → /og/getting-started/installation.png
//          root /                              → /og/index.png
//
// The matching PNG must exist in public/og/ before building; the render
// script walks src/content/docs/**/*.{md,mdx} and writes one PNG per
// page to mirror the URL tree.
import Default from "@astrojs/starlight/components/Head.astro";

const pathname = Astro.url.pathname.replace(/^\/+|\/+$/g, "");
const slug = pathname === "" ? "index" : pathname;
const ogUrl = new URL(`/og/${slug}.png`, Astro.site).toString();
---

<Default {...Astro.props}><slot /></Default>

<!-- Per-page OG image (generated by npm run render:og) -->
<meta property="og:image" content={ogUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:type" content="image/png" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:image" content={ogUrl} />
