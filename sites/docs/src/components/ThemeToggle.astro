---
/**
 * Replacement for Starlight's ThemeSelect dropdown.
 * Simple two-state toggle: light ⇄ dark. No "auto" option — a toggle
 * has to commit to one state, otherwise a second click on a system-dark
 * user produces no visible change.
 *
 * Compatible with Starlight's theme storage ('starlight-theme' key) and
 * with StarlightThemeProvider.updatePickers(), so other pickers on the
 * page (if any) stay in sync.
 */
---

<starlight-theme-toggle>
	<button
		type="button"
		class="theme-toggle"
		aria-label="Toggle color theme"
		title="Toggle color theme"
	>
		{/* Sun — shown in dark mode (click to go light) */}
		<svg
			class="icon sun"
			xmlns="http://www.w3.org/2000/svg"
			width="18"
			height="18"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round"
			aria-hidden="true"
		>
			<circle cx="12" cy="12" r="4"></circle>
			<path d="M12 2v2"></path>
			<path d="M12 20v2"></path>
			<path d="m4.93 4.93 1.41 1.41"></path>
			<path d="m17.66 17.66 1.41 1.41"></path>
			<path d="M2 12h2"></path>
			<path d="M20 12h2"></path>
			<path d="m6.34 17.66-1.41 1.41"></path>
			<path d="m19.07 4.93-1.41 1.41"></path>
		</svg>
		{/* Moon — shown in light mode (click to go dark) */}
		<svg
			class="icon moon"
			xmlns="http://www.w3.org/2000/svg"
			width="18"
			height="18"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round"
			aria-hidden="true"
		>
			<path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
		</svg>
	</button>
</starlight-theme-toggle>

<script is:inline>
	// Keep any other pickers on the page in sync when this one mounts.
	StarlightThemeProvider.updatePickers();
</script>

<script>
	type Theme = 'dark' | 'light';

	const storageKey = 'starlight-theme';

	function preferredScheme(): Theme {
		return matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
	}

	function currentTheme(): Theme {
		const stored = typeof localStorage !== 'undefined' ? localStorage.getItem(storageKey) : null;
		if (stored === 'light' || stored === 'dark') return stored;
		return preferredScheme();
	}

	function applyTheme(theme: Theme): void {
		document.documentElement.dataset.theme = theme;
		if (typeof localStorage !== 'undefined') {
			localStorage.setItem(storageKey, theme);
		}
		// Keep any Starlight default select pickers in sync.
		// @ts-ignore — provided by StarlightThemeProvider inline script.
		if (typeof StarlightThemeProvider !== 'undefined') StarlightThemeProvider.updatePickers(theme);
	}

	class StarlightThemeToggle extends HTMLElement {
		constructor() {
			super();
			const button = this.querySelector('button');
			if (!button) return;
			// Normalize the document state on mount so a stored "auto" or
			// an empty value resolves to a concrete light/dark class.
			applyTheme(currentTheme());
			button.addEventListener('click', () => {
				const next: Theme = currentTheme() === 'dark' ? 'light' : 'dark';
				applyTheme(next);
			});
		}
	}

	customElements.define('starlight-theme-toggle', StarlightThemeToggle);
</script>

<style>
	starlight-theme-toggle {
		display: inline-flex;
		align-items: center;
	}

	.theme-toggle {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2rem;
		height: 2rem;
		padding: 0;
		border: 1px solid var(--sl-color-hairline-light);
		border-radius: 10px;
		background: var(--sl-color-bg);
		color: var(--sl-color-text);
		cursor: pointer;
		transition: border-color 0.15s ease, color 0.15s ease, background 0.15s ease;
	}

	.theme-toggle:hover {
		border-color: var(--club-primary, var(--sl-color-accent));
		color: var(--club-primary, var(--sl-color-accent));
	}

	.theme-toggle:focus-visible {
		outline: none;
		box-shadow: 0 0 0 4px var(--club-ring, rgba(255, 79, 24, 0.28));
	}

	.icon {
		display: block;
	}

	/* Sun = shown in dark mode, moon = shown in light mode. */
	:root[data-theme='light'] .sun,
	:root[data-theme='dark'] .moon {
		display: none;
	}

	:global(:root[data-theme='dark']) .theme-toggle {
		background: #111111;
	}
</style>
