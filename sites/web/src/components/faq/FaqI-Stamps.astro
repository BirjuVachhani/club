---
// FAQ — Variant I · Postal stamps
// On-brand for CLUB ("rubber stamp" mark). Each FAQ is a postage stamp:
// perforated edge, denomination corner, "POSTED" cancellation mark on
// the question. Compact 3-column grid, every answer visible.
import { FAQS, FAQ_CATEGORIES } from "../../lib/landing-copy";
---

<section id="faq" class="sec">
  <div class="wrap">
    <header class="head">
      <span class="ribbon">
        <span class="ribbon-dot"></span>
        Stamped & filed · Issue {FAQS.length}
      </span>
      <h2 class="h2">The questions, postmarked & catalogued.</h2>
      <p class="lede">
        We collect every question we get into the file. Pick a stamp,
        read the back. The whole catalog fits on this page.
      </p>
    </header>

    <ul class="sheet">
      {FAQS.map((f, i) => (
        <li class="stamp">
          <div class="stamp-edge">
            <article class="stamp-face">
              <header class="face-head">
                <span class="denom">N° {String(i + 1).padStart(2, "0")}</span>
                <span class="series">{FAQ_CATEGORIES[f.cat].label}</span>
              </header>

              <div class="cancel" aria-hidden="true">
                <span class="cancel-mark">CLUB · POSTED · CLUB · POSTED</span>
                <span class="cancel-mark second">CLUB · POSTED · CLUB · POSTED</span>
              </div>

              <h3 class="q">{f.q}</h3>
              <p class="a">{f.a}</p>

              <footer class="face-foot">
                <span class="postmark">
                  <span class="pm-ring">
                    <span class="pm-inner">CLUB</span>
                  </span>
                </span>
                <span class="filed">Filed · 2026</span>
              </footer>
            </article>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .sec {
    padding: 6rem 0;
    background:
      repeating-linear-gradient(
        45deg,
        var(--color-paper-mute) 0,
        var(--color-paper-mute) 14px,
        var(--color-paper-mute-2) 14px,
        var(--color-paper-mute-2) 28px
      );
    border-top: 1px solid var(--color-border);
  }
  .wrap { max-width: 84rem; margin: 0 auto; padding: 0 2.5rem; }
  @media (max-width: 768px) { .wrap { padding: 0 1.25rem; } .sec { padding: 4.5rem 0; } }

  .head { max-width: 50rem; margin-bottom: 3rem; }
  .ribbon {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.35rem 0.75rem;
    background: var(--color-stamp); color: #FFFFFF;
    font-family: var(--font-mono); font-size: 0.66rem; font-weight: 700;
    letter-spacing: 0.16em; text-transform: uppercase;
    border-radius: 3px;
    box-shadow: 0 2px 0 0 var(--color-stamp-hover);
  }
  .ribbon-dot {
    width: 6px; height: 6px; border-radius: 999px; background: #FFFFFF;
    box-shadow: 0 0 0 2px rgba(255,255,255,0.25);
  }
  .h2 {
    font-family: var(--font-sans); font-weight: 680;
    font-size: clamp(1.85rem, 2.5vw + 0.75rem, 2.6rem);
    letter-spacing: -0.022em; line-height: 1.1; margin: 1rem 0 0;
    max-width: 22ch; color: var(--color-ink);
  }
  .lede {
    font-size: 1rem; line-height: 1.6; color: var(--color-mute);
    margin: 1.25rem 0 0; max-width: 36rem;
  }

  .sheet {
    list-style: none; padding: 0; margin: 0;
    display: grid; gap: 1.5rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
  @media (max-width: 1000px) { .sheet { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 700px)  { .sheet { grid-template-columns: 1fr; } }

  .stamp {
    /* Outer perforated edge built with a radial-gradient mask */
    --notch: 7px;
    --notch-spacing: 14px;
  }
  .stamp-edge {
    background: var(--color-stamp);
    padding: 8px;
    border-radius: 3px;
    /* Perforations cut out of the stamp edge */
    --mask:
      radial-gradient(circle var(--notch) at calc(var(--notch-spacing) / 2) 0, transparent 99%, #000 100%) repeat-x 0 0 / var(--notch-spacing) var(--notch),
      radial-gradient(circle var(--notch) at calc(var(--notch-spacing) / 2) 100%, transparent 99%, #000 100%) repeat-x 0 100% / var(--notch-spacing) var(--notch),
      radial-gradient(circle var(--notch) at 0 calc(var(--notch-spacing) / 2), transparent 99%, #000 100%) repeat-y 0 0 / var(--notch) var(--notch-spacing),
      radial-gradient(circle var(--notch) at 100% calc(var(--notch-spacing) / 2), transparent 99%, #000 100%) repeat-y 100% 0 / var(--notch) var(--notch-spacing),
      linear-gradient(#000, #000);
    -webkit-mask: var(--mask);
            mask: var(--mask);
    -webkit-mask-composite: source-over;
            mask-composite: add;
    box-shadow:
      0 16px 28px -16px rgba(20,21,23,0.3),
      0 2px 4px rgba(20,21,23,0.06);
    transition: transform 200ms ease;
  }
  .stamp:hover .stamp-edge { transform: translateY(-3px) rotate(-0.4deg); }

  .stamp-face {
    position: relative;
    background: #FCFAF3;
    padding: 1.5rem 1.4rem 1.35rem;
    border-radius: 1px;
    overflow: hidden;
    display: flex; flex-direction: column; height: 100%;
  }

  .face-head {
    display: flex; justify-content: space-between; align-items: center;
    gap: 0.5rem;
    padding-bottom: 0.85rem;
    border-bottom: 1.5px solid color-mix(in oklab, var(--color-ink) 12%, transparent);
    border-bottom-style: dashed;
  }
  .denom {
    font-family: var(--font-mono); font-size: 0.72rem; font-weight: 700;
    letter-spacing: 0.14em; color: var(--color-stamp);
  }
  .series {
    font-family: var(--font-mono); font-size: 0.58rem; font-weight: 700;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--color-ink);
    background: color-mix(in oklab, var(--color-stamp) 12%, transparent);
    padding: 0.18rem 0.5rem; border-radius: 2px;
  }

  /* Cancellation marks — wavy lines + repeated text, slightly off-axis */
  .cancel {
    position: absolute; top: 28%; left: -10%; right: -10%;
    transform: rotate(-6deg); pointer-events: none;
    opacity: 0.10;
  }
  .cancel-mark {
    display: block;
    font-family: var(--font-mono); font-weight: 700;
    font-size: 0.95rem; letter-spacing: 0.25em;
    color: var(--color-ink); white-space: nowrap;
  }
  .cancel-mark.second { margin-top: 0.5rem; }

  .q {
    position: relative;
    font-family: var(--font-sans); font-weight: 660;
    font-size: 1rem; line-height: 1.3; letter-spacing: -0.014em;
    margin: 1rem 0 0; color: var(--color-ink);
  }
  .a {
    position: relative;
    margin: 0.55rem 0 0;
    font-size: 0.88rem; line-height: 1.55;
    color: color-mix(in oklab, var(--color-ink) 65%, transparent);
  }

  .face-foot {
    margin-top: auto; padding-top: 1rem;
    display: flex; align-items: center; justify-content: space-between; gap: 0.75rem;
  }
  .filed {
    font-family: var(--font-mono); font-size: 0.6rem;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--color-mute); font-weight: 600;
  }

  /* Round postmark */
  .postmark {
    width: 44px; height: 44px;
    display: grid; place-items: center;
    transform: rotate(-8deg);
  }
  .pm-ring {
    width: 44px; height: 44px; border-radius: 999px;
    border: 1.5px solid var(--color-stamp);
    box-shadow: inset 0 0 0 3px transparent, inset 0 0 0 4px var(--color-stamp);
    display: grid; place-items: center;
    color: var(--color-stamp);
    opacity: 0.65;
  }
  .pm-inner {
    font-family: var(--font-mono); font-size: 0.6rem; font-weight: 800;
    letter-spacing: 0.12em;
  }
</style>
