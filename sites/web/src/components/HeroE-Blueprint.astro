---
import { docsUrl, GITHUB_URL } from "../lib/config";
---

<!--
  HeroE — "Blueprint"
  Technical schematic on a faint blueprint grid. Shows the system as
  a draftsman's diagram: client → CLUB → storage. Dimension marks,
  node labels, callouts. Feels like a spec sheet.
-->
<section
  class="relative overflow-hidden"
  style="background: var(--color-paper-mute); color: var(--color-ink);"
>
  <!-- blueprint grid -->
  <div
    class="pointer-events-none absolute inset-0"
    style="
      background-image:
        linear-gradient(var(--color-border) 1px, transparent 1px),
        linear-gradient(90deg, var(--color-border) 1px, transparent 1px),
        linear-gradient(color-mix(in oklab, var(--color-border) 55%, transparent) 1px, transparent 1px),
        linear-gradient(90deg, color-mix(in oklab, var(--color-border) 55%, transparent) 1px, transparent 1px);
      background-size: 80px 80px, 80px 80px, 16px 16px, 16px 16px;
      opacity: 0.7;
    "
  />

  <div class="relative mx-auto w-full max-w-[82rem] px-6 pb-24 pt-32 md:px-10 md:pb-28 md:pt-36">
    <!-- spec sheet header -->
    <div
      class="flex flex-wrap items-center justify-between gap-3 border-b pb-4 font-mono text-[0.68rem] tracking-[0.18em] uppercase"
      style="border-color: var(--color-ink); color: var(--color-mute);"
    >
      <div class="flex items-center gap-4">
        <span
          class="rounded-sm px-1.5 py-0.5 font-bold"
          style="background: var(--color-stamp); color: #fff; letter-spacing: 0.2em;"
        >
          SPEC
        </span>
        <span>Sheet 01 — System diagram</span>
      </div>
      <div class="flex items-center gap-4">
        <span>Rev A</span>
        <span>·</span>
        <span>Scale 1:1</span>
        <span>·</span>
        <span>Pub Spec v2</span>
      </div>
    </div>

    <div class="mt-12 grid gap-10 md:grid-cols-[minmax(0,0.4fr)_minmax(0,0.6fr)] md:gap-14">
      <!-- LEFT: copy -->
      <div>
        <div class="eyebrow" style="color: var(--color-stamp);">
          § Description
        </div>
        <h1 class="h1 mt-4 max-w-[16ch]">
          A Dart package host, <span style="color: var(--color-stamp);">drawn to spec</span>.
        </h1>
        <p class="prose-body mt-5 max-w-md">
          One Dart binary exposing the Pub Spec v2 API, fronted by your
          TLS, backed by storage you already operate. No forks, no magic —
          a diagram anyone on your team can read.
        </p>

        <div class="mt-7 flex flex-wrap items-center gap-3">
          <a href={docsUrl("/getting-started/quick-start/")} class="btn btn-primary">
            Read the spec
            <span class="btn-arrow">→</span>
          </a>
          <a href={GITHUB_URL} class="btn btn-ghost">
            View source
          </a>
        </div>

        <!-- parts list -->
        <div
          class="mt-10 border-t pt-5 font-mono text-[0.72rem]"
          style="border-color: var(--color-ink); color: var(--color-ink);"
        >
          <div class="tracking-[0.16em] uppercase" style="color: var(--color-mute);">
            Parts list
          </div>
          <ol class="mt-3 space-y-1">
            <li class="flex items-baseline gap-3">
              <span style="color: var(--color-stamp);">A</span>
              <span>dart pub client (unmodified)</span>
            </li>
            <li class="flex items-baseline gap-3">
              <span style="color: var(--color-stamp);">B</span>
              <span>CLUB server · shelf · bcrypt</span>
            </li>
            <li class="flex items-baseline gap-3">
              <span style="color: var(--color-stamp);">C</span>
              <span>SQLite + filesystem (default)</span>
            </li>
            <li class="flex items-baseline gap-3">
              <span style="color: var(--color-stamp);">C′</span>
              <span>S3-compatible (pluggable)</span>
            </li>
          </ol>
        </div>
      </div>

      <!-- RIGHT: diagram -->
      <div class="relative">
        <div
          class="relative aspect-[1.15/1] w-full rounded-md border"
          style="
            border-color: var(--color-ink);
            background: var(--color-bg);
            background-image:
              linear-gradient(color-mix(in oklab, var(--color-border) 70%, transparent) 1px, transparent 1px),
              linear-gradient(90deg, color-mix(in oklab, var(--color-border) 70%, transparent) 1px, transparent 1px);
            background-size: 22px 22px;
          "
        >
          <!-- diagram title -->
          <div
            class="absolute left-4 top-3 font-mono text-[0.64rem] tracking-[0.18em] uppercase"
            style="color: var(--color-mute);"
          >
            fig. 01 — request path
          </div>
          <div
            class="absolute right-4 top-3 font-mono text-[0.64rem] tracking-[0.18em] uppercase"
            style="color: var(--color-stamp);"
          >
            /api/packages/:name
          </div>

          <svg
            viewBox="0 0 600 520"
            class="h-full w-full"
            aria-hidden="true"
            preserveAspectRatio="xMidYMid meet"
          >
            <!-- Arrows / connectors -->
            <defs>
              <marker
                id="arr-blueprint"
                viewBox="0 0 10 10"
                refX="9"
                refY="5"
                markerWidth="6"
                markerHeight="6"
                orient="auto-start-reverse"
              >
                <path d="M 0 0 L 10 5 L 0 10 z" fill="var(--color-stamp)" />
              </marker>
            </defs>

            <!-- Path: client (A) → server (B) -->
            <path
              d="M 150 160 L 310 260"
              stroke="var(--color-ink)"
              stroke-width="1.5"
              fill="none"
              marker-end="url(#arr-blueprint)"
            />
            <!-- Path: server (B) → storage (C) -->
            <path
              d="M 400 300 L 500 400"
              stroke="var(--color-ink)"
              stroke-width="1.5"
              fill="none"
              marker-end="url(#arr-blueprint)"
            />

            <!-- Dimension line (top) -->
            <g stroke="var(--color-stamp)" stroke-width="1">
              <line x1="60" y1="70" x2="540" y2="70" />
              <line x1="60" y1="62" x2="60" y2="78" />
              <line x1="540" y1="62" x2="540" y2="78" />
            </g>
            <text
              x="300"
              y="58"
              text-anchor="middle"
              font-family="var(--font-mono)"
              font-size="11"
              fill="var(--color-stamp)"
              style="letter-spacing: 0.12em; text-transform: uppercase;"
            >
              one binary · one container
            </text>

            <!-- Node A: client -->
            <g>
              <rect
                x="60" y="120" width="180" height="90"
                fill="var(--color-bg)"
                stroke="var(--color-ink)"
                stroke-width="1.5"
                rx="4"
              />
              <text
                x="70" y="142"
                font-family="var(--font-mono)"
                font-size="10"
                fill="var(--color-stamp)"
                style="letter-spacing: 0.14em;"
              >A — CLIENT</text>
              <text
                x="70" y="172"
                font-family="var(--font-sans)"
                font-size="17"
                font-weight="640"
                fill="var(--color-ink)"
              >dart pub</text>
              <text
                x="70" y="193"
                font-family="var(--font-mono)"
                font-size="10"
                fill="var(--color-mute)"
              >unmodified · TLS</text>
            </g>

            <!-- Node B: CLUB -->
            <g>
              <rect
                x="310" y="230" width="200" height="110"
                fill="var(--color-ink)"
                stroke="var(--color-ink)"
                stroke-width="1.5"
                rx="6"
              />
              <rect
                x="314" y="234" width="192" height="102"
                fill="none"
                stroke="var(--color-stamp)"
                stroke-width="1"
                stroke-dasharray="3 3"
                rx="4"
              />
              <text
                x="320" y="254"
                font-family="var(--font-mono)"
                font-size="10"
                fill="var(--color-stamp)"
                style="letter-spacing: 0.14em;"
              >B — SERVER</text>
              <text
                x="320" y="288"
                font-family="var(--font-sans)"
                font-size="22"
                font-weight="700"
                fill="#fff"
              >CLUB</text>
              <text
                x="320" y="312"
                font-family="var(--font-mono)"
                font-size="10"
                fill="#9A9AA1"
              >shelf · bcrypt · sha-256</text>
              <text
                x="320" y="328"
                font-family="var(--font-mono)"
                font-size="10"
                fill="#9A9AA1"
              >pub spec v2 · fts5 search</text>
            </g>

            <!-- Node C: storage -->
            <g>
              <rect
                x="380" y="390" width="180" height="90"
                fill="var(--color-bg)"
                stroke="var(--color-ink)"
                stroke-width="1.5"
                rx="4"
              />
              <text
                x="390" y="412"
                font-family="var(--font-mono)"
                font-size="10"
                fill="var(--color-stamp)"
                style="letter-spacing: 0.14em;"
              >C — STORAGE</text>
              <text
                x="390" y="442"
                font-family="var(--font-sans)"
                font-size="15"
                font-weight="640"
                fill="var(--color-ink)"
              >SQLite + FS</text>
              <text
                x="390" y="463"
                font-family="var(--font-mono)"
                font-size="10"
                fill="var(--color-mute)"
              >swap: S3 · GCS · etc.</text>
            </g>

            <!-- Callout label on link A→B -->
            <g>
              <line
                x1="210" y1="195" x2="260" y2="160"
                stroke="var(--color-mute)" stroke-width="1" stroke-dasharray="2 3"
              />
              <rect
                x="262" y="142" width="100" height="24"
                fill="var(--color-bg)" stroke="var(--color-mute)" stroke-width="1" rx="3"
              />
              <text
                x="270" y="158"
                font-family="var(--font-mono)" font-size="10"
                fill="var(--color-ink)"
                style="letter-spacing: 0.1em;"
              >HTTPS · JSON</text>
            </g>

            <!-- Callout label on link B→C -->
            <g>
              <line
                x1="455" y1="355" x2="520" y2="340"
                stroke="var(--color-mute)" stroke-width="1" stroke-dasharray="2 3"
              />
              <rect
                x="520" y="320" width="70" height="24"
                fill="var(--color-bg)" stroke="var(--color-mute)" stroke-width="1" rx="3"
              />
              <text
                x="528" y="336"
                font-family="var(--font-mono)" font-size="10"
                fill="var(--color-ink)"
                style="letter-spacing: 0.1em;"
              >BLOB R/W</text>
            </g>
          </svg>
        </div>

        <!-- diagram footer -->
        <div
          class="mt-3 flex items-center justify-between font-mono text-[0.64rem] tracking-[0.16em] uppercase"
          style="color: var(--color-mute);"
        >
          <span>Drawn: 2026</span>
          <span>Sheet 01/01</span>
          <span style="color: var(--color-stamp);">Approved ✓</span>
        </div>
      </div>
    </div>
  </div>
</section>
