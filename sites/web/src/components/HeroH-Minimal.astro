---
import { docsUrl, GITHUB_URL } from "../lib/config";
---

<!--
  HeroH — "Minimal"
  Maximum restraint. A single huge word set the way the CLUB mark sets
  its own period, one short line of supporting copy, one primary action.
  Lots of white space. The quiet confidence of a finished product.
-->
<section
  class="relative"
  style="background: var(--color-bg); color: var(--color-ink);"
>
  <div
    class="mx-auto grid w-full max-w-[80rem] px-6 md:px-10"
    style="min-height: 78vh; grid-template-rows: auto 1fr auto; row-gap: 2rem; padding-top: 7.5rem; padding-bottom: 4rem;"
  >
    <!-- TOP: quiet marker row -->
    <div
      class="flex items-center justify-between font-mono text-[0.66rem] tracking-[0.22em] uppercase"
      style="color: var(--color-mute);"
    >
      <span>CLUB</span>
      <span class="hidden md:inline">Self-hosted Dart package repository</span>
      <span style="color: var(--color-stamp);">— v0.1</span>
    </div>

    <!-- MIDDLE: the one big statement -->
    <div class="flex items-center">
      <div class="max-w-[20ch]">
        <h1
          style="
            font-family: var(--font-sans);
            font-weight: 700;
            letter-spacing: -0.045em;
            line-height: 0.92;
            font-size: clamp(3.25rem, 10vw, 9.5rem);
            color: var(--color-ink);
          "
        >
          pub<span style="color: var(--color-stamp);">.</span>
          <span
            class="block"
            style="
              font-weight: 580;
              letter-spacing: -0.03em;
              font-size: 0.4em;
              line-height: 1.1;
              color: var(--color-mute);
              margin-top: 0.3em;
            "
          >
            but <em style="color: var(--color-ink); font-style: italic; font-weight: 640;">yours</em>.
          </span>
        </h1>
      </div>
    </div>

    <!-- BOTTOM: supporting band -->
    <div
      class="grid items-end gap-6 border-t pt-6 md:grid-cols-[minmax(0,0.5fr)_minmax(0,0.5fr)] md:gap-10"
      style="border-color: var(--color-border);"
    >
      <p class="prose-body max-w-md">
        An open-source, self-hosted package repository for Dart and
        Flutter teams. Pub Spec v2 compatible — your clients don't
        need to know anything has changed.
      </p>

      <div class="flex flex-col items-start gap-5 md:items-end">
        <div class="flex flex-wrap items-center gap-3">
          <a href={docsUrl("/getting-started/quick-start/")} class="btn btn-primary">
            Get started
            <span class="btn-arrow">→</span>
          </a>
          <a href={GITHUB_URL} class="btn btn-ghost">
            GitHub
          </a>
        </div>
        <div
          class="font-mono text-[0.66rem] tracking-[0.18em] uppercase"
          style="color: var(--color-mute);"
        >
          One container · open source · MIT
        </div>
      </div>
    </div>
  </div>
</section>
