---
import { docsUrl, GITHUB_URL } from "../lib/config";
---

<!--
  HeroD — "Editorial"
  Magazine/journal cover. Wide asymmetric grid with a running rule,
  issue-number marker, and oversized display text with hand-annotated
  orange marks. Left: small contents panel. Right: the headline and
  opening paragraph. Feels like a printed cover story about self-hosting.
-->
<section
  class="relative overflow-hidden"
  style="background: var(--color-bg); color: var(--color-ink);"
>
  <!-- top rule -->
  <div
    class="absolute left-0 right-0 top-0 h-[3px]"
    style="background: var(--color-ink);"
  ></div>
  <div
    class="absolute left-0 right-0 top-[3px] h-[1px]"
    style="background: var(--color-stamp);"
  ></div>

  <!-- issue bar -->
  <div
    class="relative mx-auto w-full max-w-[84rem] px-6 pt-4 md:px-10"
  >
    <div class="flex items-center justify-between font-mono text-[0.66rem] tracking-[0.2em] uppercase" style="color: var(--color-mute);">
      <span>Issue №01 — Package infrastructure</span>
      <span class="hidden md:inline">The self-hosting quarterly</span>
      <span>Dart · Flutter</span>
    </div>
  </div>

  <div class="relative mx-auto w-full max-w-[84rem] px-6 pb-24 pt-20 md:px-10 md:pb-28 md:pt-24">
    <div class="grid gap-10 md:grid-cols-[minmax(0,0.34fr)_minmax(0,0.66fr)] md:gap-14">
      <!-- Left: contents column -->
      <aside class="md:sticky md:top-24 md:self-start">
        <div class="flex items-baseline gap-3">
          <span
            class="leading-none"
            style="
              font-family: var(--font-sans);
              font-weight: 700;
              font-size: 4.25rem;
              letter-spacing: -0.05em;
              color: var(--color-stamp);
            "
          >01</span>
          <div class="font-mono text-[0.72rem] tracking-[0.16em] uppercase" style="color: var(--color-mute);">
            The Cover<br/>Story
          </div>
        </div>

        <hr class="my-5" style="border: 0; border-top: 1px solid var(--color-border);" />

        <ol class="space-y-3 text-[0.95rem]">
          <li class="flex items-baseline gap-3">
            <span class="font-mono text-[0.7rem]" style="color: var(--color-stamp);">p.01</span>
            <span>A pub.dev that lives behind your firewall</span>
          </li>
          <li class="flex items-baseline gap-3" style="color: var(--color-mute);">
            <span class="font-mono text-[0.7rem]" style="color: var(--color-stamp);">p.02</span>
            <span>One Dart binary, three storage backends</span>
          </li>
          <li class="flex items-baseline gap-3" style="color: var(--color-mute);">
            <span class="font-mono text-[0.7rem]" style="color: var(--color-stamp);">p.03</span>
            <span>Publishers, tokens, and team-scoped access</span>
          </li>
          <li class="flex items-baseline gap-3" style="color: var(--color-mute);">
            <span class="font-mono text-[0.7rem]" style="color: var(--color-stamp);">p.04</span>
            <span>The stock dart pub CLI, unmodified</span>
          </li>
        </ol>

        <hr class="my-5" style="border: 0; border-top: 1px solid var(--color-border);" />

        <div class="flex flex-wrap items-center gap-3">
          <a href={docsUrl("/getting-started/quick-start/")} class="btn btn-primary">
            Read the quick-start
            <span class="btn-arrow">→</span>
          </a>
          <a href={GITHUB_URL} class="btn btn-ghost">
            GitHub
          </a>
        </div>
      </aside>

      <!-- Right: headline column -->
      <div class="relative">
        <span class="chip">
          <span class="chip-dot"></span>
          Cover story
        </span>

        <h1
          class="mt-6 max-w-[20ch]"
          style="
            font-family: var(--font-sans);
            font-weight: 680;
            letter-spacing: -0.035em;
            line-height: 0.95;
            font-size: clamp(2.75rem, 7vw + 0.25rem, 6.25rem);
          "
        >
          The
          <span class="relative inline-block" style="white-space: nowrap;">
            <span style="color: var(--color-ink);">private pub</span>
            <svg
              aria-hidden="true"
              class="pointer-events-none absolute -bottom-2 left-0 right-0 w-full"
              viewBox="0 0 400 18"
              preserveAspectRatio="none"
              style="height: 0.6em;"
            >
              <path
                d="M2 12 C 90 4, 180 16, 260 8 S 380 10, 398 6"
                fill="none"
                stroke="var(--color-stamp)"
                stroke-width="3.5"
                stroke-linecap="round"
              />
            </svg>
          </span>
          that speaks the <em style="color: var(--color-stamp); font-style: italic;">same language</em> as pub.dev.
        </h1>

        <div
          class="mt-10 grid gap-6 border-t pt-8 md:grid-cols-[minmax(0,0.55fr)_minmax(0,0.45fr)] md:gap-12"
          style="border-color: var(--color-border);"
        >
          <!-- lead paragraph with drop cap -->
          <p class="text-[1.05rem] leading-[1.55]">
            <span
              class="float-left mr-2 mt-1"
              style="
                font-family: var(--font-sans);
                font-weight: 700;
                font-size: 3.8rem;
                line-height: 0.82;
                color: var(--color-stamp);
              "
            >C</span>
            LUB is a self-hosted package repository for Dart and Flutter
            teams. It implements the Pub Spec v2 protocol byte-for-byte,
            so the commands your engineers already run — <span class="font-mono" style="background: var(--color-stamp-soft); color: var(--color-stamp-hover); padding: 0 0.35em; border-radius: 4px;">dart pub get</span>,
            <span class="font-mono" style="background: var(--color-stamp-soft); color: var(--color-stamp-hover); padding: 0 0.35em; border-radius: 4px;">dart pub publish</span> —
            work against a server you own.
          </p>

          <!-- pull-quote style sidebar -->
          <aside
            class="relative rounded-xl border p-5"
            style="border-color: var(--color-border); background: var(--color-paper-mute);"
          >
            <div class="font-mono text-[0.65rem] tracking-[0.18em] uppercase" style="color: var(--color-stamp);">
              Dispatch
            </div>
            <blockquote
              class="mt-3"
              style="
                font-family: var(--font-sans);
                font-weight: 560;
                letter-spacing: -0.012em;
                line-height: 1.3;
                font-size: 1.15rem;
              "
            >
              “Same protocol. Same CLI. Different cloud — <em style="color: var(--color-stamp); font-style: italic;">yours</em>.”
            </blockquote>
            <div class="mt-4 font-mono text-[0.65rem] tracking-[0.14em] uppercase" style="color: var(--color-mute);">
              — The CLUB Manifest, §1
            </div>
          </aside>
        </div>

        <!-- kicker row -->
        <div
          class="mt-10 flex flex-wrap items-center gap-x-6 gap-y-2 border-t pt-5 font-mono text-[0.7rem] tracking-[0.14em] uppercase"
          style="border-color: var(--color-border); color: var(--color-mute);"
        >
          <span><span style="color: var(--color-stamp);">§</span> Self-hosted</span>
          <span><span style="color: var(--color-stamp);">§</span> Docker-native</span>
          <span><span style="color: var(--color-stamp);">§</span> Bcrypt + SHA-256</span>
          <span><span style="color: var(--color-stamp);">§</span> FTS5 search</span>
          <span><span style="color: var(--color-stamp);">§</span> MIT license</span>
        </div>
      </div>
    </div>
  </div>
</section>
