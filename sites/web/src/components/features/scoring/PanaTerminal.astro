---
// Scoring variant H — "pana terminal"
// Shows pana running on publish, printing the same output pub.dev
// would. Copy is tight; the terminal carries the credibility. Good
// when the audience is technical buyers who want proof, not claims.
---

<section id="f-scoring" class="sec">
  <div class="wrap">
    <div class="grid">
      <div class="copy" data-reveal>
        <div class="eyebrow orange">§ Quality</div>
        <h2 class="h2">
          Pub Scoring <span class="orange">on every publish</span>.
        </h2>
        <p class="lede">
          The actual <a href="https://dart.dev">Dart</a> tooling <a href="https://pub.dev">pub.dev</a> uses to score packages:
          scored against the same five criteria as <a href="https://pub.dev">pub.dev</a>. Pub points
          measure what matters — conventions, documentation, platform
          support, static analysis, and dependency health.
        </p>

        <ul class="bullets" data-reveal-children data-reveal-step="70" data-reveal-base="180">
          <li><strong>Same tool</strong> — <a href="https://pub.dev/packages/pana" class="mono">pana</a> from the <a href="https://dart.dev">Dart</a> team, versioned alongside the SDK.</li>
          <li><strong>Same rubric</strong> — 5 criteria, 160 points, no local modifications.</li>
          <li><strong>Your server</strong> — runs in-process; the report never leaves your infra.</li>
        </ul>

      </div>

      <!-- Terminal -->
      <figure class="term" data-reveal="right">
        <header class="term-head">
          <span class="dot"></span><span class="dot"></span><span class="dot"></span>
          <span class="term-title mono">club-server · pana</span>
        </header>
        <pre><code><span class="o">Scoring package acme_ui...</span>
<span class="m">Running dart analyze...</span>
<span class="m">Running platform detection...</span>
<span class="m">Running dartdoc...</span>
<span class="m">Running dependency check...</span>

<span class="h">Pub Points</span>
<span class="m">Section</span>                                      <span class="m">Grade</span>   <span class="m">Max</span>
<span class="ok">✓</span> Follow Dart file conventions               <span class="o">30</span>      30
<span class="ok">✓</span> Provide documentation                      <span class="o">20</span>      20
<span class="ok">✓</span> Platform support                           <span class="o">20</span>      20
<span class="w">⚠</span> Pass static analysis                       <span class="o">40</span>      50
  └─ <span class="m">2 warnings in lib/src/theme.dart</span>
<span class="w">⚠</span> Support up-to-date dependencies            <span class="o">30</span>      40
  └─ <span class="m">1 deprecated release in graph</span>

<span class="h">TOTAL                                       </span><span class="o big">140</span>     160

<span class="m">elapsed: 4.7s · package scored</span>
<span class="p cursor">▍</span></code></pre>
      </figure>
    </div>

  </div>
</section>

<style>
  .sec { padding: 6rem 0; background: var(--color-bg); }
  .wrap { max-width: 86rem; margin: 0 auto; padding: 0 2.5rem; }
  @media (max-width: 768px) { .sec { padding: 3.5rem 0; } .wrap { padding: 0 1.25rem; } }

  .orange { color: var(--color-stamp); }
  .mono { font-family: var(--font-mono); }
  .tag-in { font-size: 0.62rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--color-stamp); font-weight: 700; margin-right: 0.5rem; background: var(--color-stamp-soft); padding: 0.15rem 0.4rem; border-radius: 4px; }

  .grid {
    display: grid; gap: 3rem; align-items: center;
    grid-template-columns: minmax(0, 0.44fr) minmax(0, 0.56fr);
  }
  @media (max-width: 1000px) {
    .grid { grid-template-columns: 1fr; }
    /* Stacked: terminal mock above, copy below */
    .term { order: 1; }
    .copy { order: 2; }
  }

  .eyebrow { font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.18em; text-transform: uppercase; font-weight: 600; color: var(--color-mute); }
  .eyebrow.orange { color: var(--color-stamp); }
  .h2 { font-family: var(--font-sans); font-weight: 680; font-size: clamp(1.85rem, 2.5vw + 0.75rem, 2.75rem); letter-spacing: -0.022em; line-height: 1.1; margin: 1rem 0 0; max-width: 16ch; color: var(--color-ink); }
  .h2 .ink { color: var(--color-ink); background: var(--color-stamp-soft); padding: 0 0.3em; border-radius: 6px; font-size: 0.92em; }

  .lede { font-size: 1.1rem; line-height: 1.55; color: var(--color-mute); margin: 1.5rem 0 0; max-width: 38rem; }

  .bullets { list-style: none; padding: 0; margin: 1.75rem 0 0; display: flex; flex-direction: column; gap: 0.75rem; }
  .bullets li { position: relative; padding-left: 1.3rem; font-size: 0.95rem; line-height: 1.55; color: var(--color-mute); }
  .bullets li::before { content: "·"; position: absolute; left: 0.35rem; top: -0.05em; color: var(--color-stamp); font-weight: 700; font-family: var(--font-mono); font-size: 1.1em; }
  .bullets strong { color: var(--color-ink); font-weight: 640; }
  .bullets .mono { background: var(--color-paper-mute); padding: 0 0.3em; border-radius: 4px; font-size: 0.9em; color: var(--color-ink); }

  .proof {
    margin-top: 1.75rem; padding: 0.85rem 1.1rem;
    border: 1px solid var(--color-border); background: var(--color-paper-mute);
    border-radius: 10px;
    display: flex; flex-direction: column; gap: 0.35rem;
  }
  .proof-k { font-size: 0.62rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--color-stamp); font-weight: 700; }
  .proof code { font-size: 0.92rem; color: var(--color-ink); background: var(--color-bg); border: 1px solid var(--color-border); padding: 0.35rem 0.6rem; border-radius: 6px; display: inline-block; width: fit-content; }

  /* Terminal */
  .term {
    margin: 0; background: #050505; color: #EDEDED;
    border: 1px solid var(--color-border-dark); border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 30px 60px -30px rgba(5,5,5,0.45);
  }
  .term-head {
    display: flex; align-items: center; gap: 0.4rem;
    padding: 0.7rem 0.9rem; border-bottom: 1px solid var(--color-border-dark);
    background: #0E0E10;
  }
  .dot { width: 10px; height: 10px; border-radius: 999px; background: #3a3a3a; }
  .term-title { margin-left: auto; font-size: 0.65rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-mute-dark); }
  .term pre { margin: 0; padding: 1.25rem 1.25rem; font-family: var(--font-mono); font-size: 0.82rem; line-height: 1.75; color: #EDEDED; overflow-x: auto; white-space: pre; }
  @media (max-width: 768px) {
    .term pre { padding: 1rem; font-size: 0.72rem; line-height: 1.6; }
  }
  .term .p { color: var(--color-stamp); }
  .term .o { color: var(--color-stamp); font-weight: 600; }
  .term .o.big { font-size: 1.2em; font-weight: 700; }
  .term .m { color: var(--color-mute-dark); }
  .term .h { color: #EDEDED; font-weight: 700; display: inline-block; margin-top: 0.2em; }
  .term .ok { color: var(--color-stamp); font-weight: 700; }
  .term .w { color: #E8B84A; font-weight: 700; }
  .cursor { display: inline-block; width: 0.55em; background: var(--color-stamp); color: transparent; animation: blink 1.1s step-end infinite; }
  @keyframes blink { 0%,50%{opacity:1} 51%,100%{opacity:0} }

  .footnote {
    margin-top: 2rem; padding: 0.85rem 1.1rem;
    border: 1px dashed var(--color-border); border-radius: 8px;
    font-size: 0.88rem; color: var(--color-mute); line-height: 1.5;
  }
  .footnote strong { color: var(--color-ink); font-weight: 640; }
</style>
