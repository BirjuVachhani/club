---
// Header variant C — "Floating pill"
// Not a full-width bar. The nav is a pill-shaped capsule floating
// centered at the top, with glassy backdrop-blur so hero content
// shows through behind. Feels lighter, more modern.
import Mark from "../Mark.astro";
import { docsUrl, GITHUB_URL } from "../../lib/config";
---

<header class="site-nav">
  <a href="/" class="site-nav-brand" aria-label="CLUB home">
    <Mark height={24} />
  </a>
  <nav class="site-nav-links">
    <a href="/#f-private">Features</a>
    <a href="/#faq">FAQ</a>
    <a href="/#f-donate">Donate</a>
    <a href={docsUrl()}>Docs ↗</a>
  </nav>
  <div class="site-nav-cta">
    <a href={GITHUB_URL} class="ghost" aria-label="GitHub">
      <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
        <path d="M8 0C3.58 0 0 3.58 0 8a8 8 0 005.47 7.59c.4.07.55-.17.55-.38v-1.33c-2.22.48-2.69-1.07-2.69-1.07-.36-.92-.89-1.17-.89-1.17-.73-.5.05-.49.05-.49.81.06 1.24.83 1.24.83.72 1.23 1.88.88 2.34.67.07-.52.28-.88.51-1.08-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82A7.6 7.6 0 018 4.8c.68 0 1.36.09 2 .27 1.53-1.03 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.28.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48v2.2c0 .21.15.46.55.38A8 8 0 0016 8c0-4.42-3.58-8-8-8z"/>
      </svg>
    </a>
    <a href={docsUrl("/getting-started/quick-start/")} class="primary">
      Get started
      <span class="arrow">→</span>
    </a>
  </div>
</header>

<style>
  .site-nav {
    position: fixed;
    top: 1rem;
    left: 1rem;
    right: 1rem;
    margin-inline: auto;
    z-index: 40;
    display: flex; align-items: center; justify-content: space-between; gap: 1.5rem;
    padding: 0.6rem 0.5rem 0.6rem 1rem;
    width: min(64rem, calc(100% - 2rem));
    border-radius: 999px;
    background: color-mix(in oklab, var(--color-ink-dark) 45%, transparent);
    backdrop-filter: saturate(1.5) blur(20px);
    -webkit-backdrop-filter: saturate(1.5) blur(20px);
    border: 1px solid color-mix(in oklab, #EDEDED 14%, transparent);
    color: #EDEDED;
    box-shadow: 0 14px 32px -14px rgba(0,0,0,0.5), 0 0 0 3px color-mix(in oklab, #050505 20%, transparent);
    opacity: 0;
    animation: nav-drop 720ms var(--ease-out-quart, cubic-bezier(0.25, 1, 0.5, 1)) 120ms forwards;
    transition: border-color 240ms ease-out, box-shadow 240ms ease-out;
  }
  @keyframes nav-drop {
    from { opacity: 0; top: 0.5rem; }
    to   { opacity: 1; top: 1rem; }
  }
  @media (prefers-reduced-motion: reduce) {
    .site-nav { opacity: 1; animation: none; }
  }
  @media (max-width: 480px) {
    .site-nav {
      gap: 0.5rem;
      padding: 0.45rem 0.4rem 0.45rem 0.75rem;
    }
  }
  .site-nav-brand { transition: transform 260ms var(--ease-out-quart, cubic-bezier(0.25, 1, 0.5, 1)); }
  .site-nav-brand:hover { transform: rotate(-4deg) scale(1.06); }
  @media (prefers-reduced-motion: reduce) {
    .site-nav-brand:hover { transform: none; }
  }

  .site-nav-brand { display: flex; align-items: center; }

  .site-nav-links {
    display: flex; gap: 1.1rem; font-size: 0.82rem;
  }
  @media (max-width: 820px) { .site-nav-links { display: none; } }
  .site-nav-links a {
    color: #EDEDED; opacity: 0.78;
    transition: opacity 150ms;
    padding: 0.15rem 0;
  }
  .site-nav-links a:hover { opacity: 1; }

  .site-nav-cta { display: flex; gap: 0.35rem; align-items: center; }

  .ghost {
    display: inline-flex; align-items: center; justify-content: center;
    width: 2rem; height: 2rem; border-radius: 999px;
    background: color-mix(in oklab, #EDEDED 8%, transparent);
    color: #EDEDED;
    transition: background 150ms, color 150ms;
  }
  .ghost:hover { background: #fff; color: var(--color-ink); }

  .primary {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.5em calc(1em + 4px) 0.5em 1em; border-radius: 999px;
    background: var(--color-stamp); color: #fff;
    font-family: var(--font-sans); font-size: 0.82rem; font-weight: 640;
    min-height: 2.25rem;
    transition: background 150ms;
  }
  @media (max-width: 480px) {
    .primary { font-size: 0.78rem; padding: 0.45em 0.85em; }
    .primary .arrow { display: none; }
  }
  .primary:hover { background: var(--color-stamp-hover); }
  .arrow { transition: transform 180ms cubic-bezier(.2,.8,.2,1); }
  .primary:hover .arrow { transform: translateX(2px); }
</style>
