---
// Header variant D — "Announcement row + nav"
// Two-row header: a thin stamp-orange ribbon on top carrying a product
// announcement / release note, then the main nav below. Pattern used
// by many SaaS sites to promote launches.
import Mark from "../Mark.astro";
import { docsUrl, GITHUB_URL } from "../../lib/config";
---

<div class="site-nav-stack">
  <!-- Announcement ribbon -->
  <a href={docsUrl("/changelog/")} class="banner">
    <span class="banner-tag mono">✦ New</span>
    <span class="banner-body">CLUB v0.1 is out — read the release notes</span>
    <span class="banner-arrow">→</span>
  </a>

  <!-- Main nav -->
  <header class="site-nav">
    <div class="site-nav-inner">
      <a href="/" class="site-nav-brand" aria-label="CLUB home">
        <Mark height={28} />
      </a>
      <nav class="site-nav-links">
        <a href="#publish">Publish</a>
        <a href="#f-private">Features</a>
        <a href="#faq">FAQ</a>
        <a href="#f-donate">Donate</a>
        <a href={docsUrl()}>Docs ↗</a>
      </nav>
      <div class="site-nav-cta">
        <a href={GITHUB_URL} class="btn btn-ghost">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M8 0C3.58 0 0 3.58 0 8a8 8 0 005.47 7.59c.4.07.55-.17.55-.38v-1.33c-2.22.48-2.69-1.07-2.69-1.07-.36-.92-.89-1.17-.89-1.17-.73-.5.05-.49.05-.49.81.06 1.24.83 1.24.83.72 1.23 1.88.88 2.34.67.07-.52.28-.88.51-1.08-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82A7.6 7.6 0 018 4.8c.68 0 1.36.09 2 .27 1.53-1.03 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.28.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48v2.2c0 .21.15.46.55.38A8 8 0 0016 8c0-4.42-3.58-8-8-8z"/>
          </svg>
          GitHub
        </a>
        <a href={docsUrl("/getting-started/quick-start/")} class="btn btn-primary">
          Get started <span class="btn-arrow">→</span>
        </a>
      </div>
    </div>
  </header>
</div>

<style>
  .site-nav-stack { position: sticky; top: 0; z-index: 40; }

  /* Announcement banner */
  .banner {
    display: flex; align-items: center; justify-content: center;
    gap: 0.6rem; padding: 0.5rem 1rem;
    background: var(--color-stamp); color: #fff;
    font-family: var(--font-sans); font-weight: 600; font-size: 0.82rem;
    letter-spacing: -0.005em;
    transition: background 150ms;
  }
  .banner:hover { background: var(--color-stamp-hover); }
  .banner-tag {
    font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase;
    font-weight: 700;
    padding: 0.15rem 0.45rem; border-radius: 3px;
    background: rgba(0,0,0,0.22); color: #fff;
  }
  .banner-body { color: #fff; }
  .banner-arrow {
    font-weight: 700;
    transition: transform 180ms cubic-bezier(.2,.8,.2,1);
  }
  .banner:hover .banner-arrow { transform: translateX(2px); }
  .mono { font-family: var(--font-mono); }

  /* Main nav — reuses the A/dark-centered pattern */
  .site-nav {
    background: var(--color-ink-dark);
    border-bottom: 1px solid var(--color-border-dark);
    color: #EDEDED;
  }
  .site-nav-inner {
    display: grid; grid-template-columns: 1fr auto 1fr;
    align-items: center; gap: 2rem;
    padding: 0.7rem 2.5rem;
    max-width: 84rem; margin: 0 auto;
  }
  @media (max-width: 768px) { .site-nav-inner { padding: 0.6rem 1.25rem; gap: 1rem; } }

  .site-nav-brand { justify-self: start; display: flex; align-items: center; }
  .site-nav-links { justify-self: center; display: flex; gap: 1.75rem; font-size: 0.88rem; }
  @media (max-width: 900px) { .site-nav-links { display: none; } }
  .site-nav-links a { color: #EDEDED; opacity: 0.75; transition: opacity 150ms; }
  .site-nav-links a:hover { opacity: 1; }

  .site-nav-cta { justify-self: end; display: flex; gap: 0.5rem; align-items: center; }
  .site-nav-cta .btn-ghost { color: #EDEDED; }
</style>
