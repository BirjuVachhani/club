---
// Header variant E — "Command palette"
// Dev-tool / Linear / Vercel flavor. The middle of the nav is a
// centered fake search input (⌘K-style) instead of text links. The
// kbd hint sits on the right of the input. Nav links flank it as
// smaller chips.
import Mark from "../Mark.astro";
import { docsUrl, GITHUB_URL } from "../../lib/config";
---

<header class="site-nav">
  <div class="site-nav-inner">
    <!-- Left: brand + compact nav chips -->
    <div class="left">
      <a href="/" class="site-nav-brand" aria-label="CLUB home">
        <Mark height={24} />
      </a>
      <nav class="chips">
        <a href="#f-private">Features</a>
        <a href="#faq">FAQ</a>
        <a href="#f-donate">Donate</a>
        <a href={docsUrl()}>Docs</a>
      </nav>
    </div>

    <!-- Center: fake ⌘K trigger -->
    <button class="cmdk" type="button" aria-label="Search">
      <span class="cmdk-icon" aria-hidden="true">⌕</span>
      <span class="cmdk-placeholder">Search docs, API, commands…</span>
      <span class="kbd">
        <kbd>⌘</kbd><kbd>K</kbd>
      </span>
    </button>

    <!-- Right: CTAs -->
    <div class="cta">
      <a href={GITHUB_URL} class="ghost" aria-label="GitHub">
        <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8a8 8 0 005.47 7.59c.4.07.55-.17.55-.38v-1.33c-2.22.48-2.69-1.07-2.69-1.07-.36-.92-.89-1.17-.89-1.17-.73-.5.05-.49.05-.49.81.06 1.24.83 1.24.83.72 1.23 1.88.88 2.34.67.07-.52.28-.88.51-1.08-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82A7.6 7.6 0 018 4.8c.68 0 1.36.09 2 .27 1.53-1.03 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.28.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48v2.2c0 .21.15.46.55.38A8 8 0 0016 8c0-4.42-3.58-8-8-8z"/>
        </svg>
      </a>
      <a href={docsUrl("/getting-started/quick-start/")} class="primary">
        Get started
        <span class="arrow">→</span>
      </a>
    </div>
  </div>
</header>

<style>
  .site-nav {
    position: sticky; top: 0; z-index: 40;
    background: var(--color-ink-dark);
    border-bottom: 1px solid var(--color-border-dark);
    color: #EDEDED;
  }
  .site-nav-inner {
    display: grid; grid-template-columns: minmax(0, 1fr) minmax(12rem, 26rem) auto;
    align-items: center; gap: 1.25rem;
    padding: 0.7rem 1.5rem;
    max-width: 86rem; margin: 0 auto;
  }
  @media (max-width: 900px) { .site-nav-inner { grid-template-columns: auto 1fr auto; padding: 0.65rem 1.25rem; } }

  /* Left */
  .left { display: flex; align-items: center; gap: 1.5rem; min-width: 0; }
  .site-nav-brand { display: flex; align-items: center; }
  .chips {
    display: flex; gap: 0.35rem;
    padding-left: 1rem;
    border-left: 1px solid var(--color-border-dark);
  }
  @media (max-width: 1000px) { .chips { display: none; } }
  .chips a {
    font-size: 0.78rem;
    padding: 0.3rem 0.65rem; border-radius: 6px;
    color: #EDEDED; opacity: 0.78;
    transition: background 150ms, opacity 150ms;
  }
  .chips a:hover {
    opacity: 1;
    background: color-mix(in oklab, #EDEDED 7%, transparent);
  }

  /* ⌘K search */
  .cmdk {
    display: flex; align-items: center; gap: 0.6rem;
    padding: 0.45rem 0.65rem 0.45rem 0.85rem;
    background: color-mix(in oklab, #EDEDED 4%, transparent);
    border: 1px solid var(--color-border-dark);
    border-radius: 10px;
    color: var(--color-mute-dark);
    font-family: var(--font-sans); font-size: 0.82rem;
    cursor: text; text-align: left;
    transition: border-color 150ms, background 150ms;
  }
  .cmdk:hover { border-color: color-mix(in oklab, var(--color-stamp) 50%, var(--color-border-dark)); }
  .cmdk-icon { font-size: 0.95rem; opacity: 0.7; }
  .cmdk-placeholder { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  @media (max-width: 600px) { .cmdk-placeholder { display: none; } .cmdk { padding: 0.45rem 0.65rem; } }

  .kbd { display: inline-flex; gap: 0.15rem; }
  .kbd kbd {
    font-family: var(--font-mono); font-size: 0.65rem; font-weight: 600;
    padding: 0.1rem 0.3rem; border-radius: 4px;
    background: color-mix(in oklab, #EDEDED 8%, transparent);
    border: 1px solid var(--color-border-dark);
    color: #EDEDED;
  }

  /* Right */
  .cta { display: flex; align-items: center; gap: 0.35rem; justify-self: end; }

  .ghost {
    display: inline-flex; align-items: center; justify-content: center;
    width: 2.1rem; height: 2.1rem; border-radius: 8px;
    color: #EDEDED;
    border: 1px solid transparent;
    transition: background 150ms, border-color 150ms;
  }
  .ghost:hover { background: color-mix(in oklab, #EDEDED 7%, transparent); border-color: var(--color-border-dark); }

  .primary {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.55em 1em; border-radius: 8px;
    background: var(--color-stamp); color: #fff;
    font-family: var(--font-sans); font-size: 0.85rem; font-weight: 640;
    transition: background 150ms;
  }
  .primary:hover { background: var(--color-stamp-hover); }
  .arrow { transition: transform 180ms cubic-bezier(.2,.8,.2,1); }
  .primary:hover .arrow { transform: translateX(2px); }
</style>
