---
// Header variant F — "Right-biased"
// Asymmetric layout: brand pinned far left, everything else (nav links
// + CTAs) clustered to the right with a subtle vertical divider
// separating nav from CTA. Minimal and editorial.
import Mark from "../Mark.astro";
import { docsUrl, GITHUB_URL } from "../../lib/config";
---

<header class="site-nav">
  <div class="site-nav-inner">
    <a href="/" class="site-nav-brand" aria-label="CLUB home">
      <Mark height={26} />
    </a>

    <div class="cluster">
      <nav class="links">
        <a href="#publish">Publish</a>
        <a href="#f-private">Features</a>
        <a href="#faq">FAQ</a>
        <a href="#f-donate">Donate</a>
        <a href={docsUrl()}>Docs ↗</a>
      </nav>

      <span class="divider" aria-hidden="true"></span>

      <div class="cta">
        <a href={GITHUB_URL} class="icon" aria-label="GitHub">
          <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M8 0C3.58 0 0 3.58 0 8a8 8 0 005.47 7.59c.4.07.55-.17.55-.38v-1.33c-2.22.48-2.69-1.07-2.69-1.07-.36-.92-.89-1.17-.89-1.17-.73-.5.05-.49.05-.49.81.06 1.24.83 1.24.83.72 1.23 1.88.88 2.34.67.07-.52.28-.88.51-1.08-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82A7.6 7.6 0 018 4.8c.68 0 1.36.09 2 .27 1.53-1.03 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.28.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48v2.2c0 .21.15.46.55.38A8 8 0 0016 8c0-4.42-3.58-8-8-8z"/>
          </svg>
        </a>
        <a href={docsUrl("/getting-started/quick-start/")} class="primary">
          Get started
          <span class="arrow">→</span>
        </a>
      </div>
    </div>
  </div>
</header>

<style>
  .site-nav {
    position: sticky; top: 0; z-index: 40;
    background: var(--color-ink-dark);
    border-bottom: 1px solid var(--color-border-dark);
    color: #EDEDED;
  }
  .site-nav-inner {
    display: flex; align-items: center; justify-content: space-between;
    gap: 2rem;
    padding: 0.75rem 2.5rem;
    max-width: 84rem; margin: 0 auto;
  }
  @media (max-width: 768px) { .site-nav-inner { padding: 0.65rem 1.25rem; gap: 1rem; } }

  .site-nav-brand { display: flex; align-items: center; }

  .cluster {
    display: flex; align-items: center; gap: 1.25rem;
  }

  .links { display: flex; gap: 1.5rem; font-size: 0.85rem; }
  @media (max-width: 900px) { .links { display: none; } }
  .links a { color: #EDEDED; opacity: 0.72; transition: opacity 150ms; }
  .links a:hover { opacity: 1; }

  .divider {
    width: 1px; height: 1.4rem;
    background: var(--color-border-dark);
  }
  @media (max-width: 900px) { .divider { display: none; } }

  .cta { display: flex; align-items: center; gap: 0.35rem; }

  .icon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 2rem; height: 2rem; border-radius: 6px;
    color: #EDEDED; opacity: 0.78;
    transition: opacity 150ms, background 150ms;
  }
  .icon:hover { opacity: 1; background: color-mix(in oklab, #EDEDED 6%, transparent); }

  .primary {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.55em 1em; border-radius: 8px;
    background: var(--color-stamp); color: #fff;
    font-family: var(--font-sans); font-size: 0.85rem; font-weight: 640;
    transition: background 150ms;
  }
  .primary:hover { background: var(--color-stamp-hover); }
  .arrow { transition: transform 180ms cubic-bezier(.2,.8,.2,1); }
  .primary:hover .arrow { transform: translateX(2px); }
</style>
