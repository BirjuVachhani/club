---
// CTA variant E2 — "Orange Brutal"
// Full-bleed orange. A solid ink-dark block on one side pins the
// content; hard edges, no gradients, Bauhaus rhythm. The primary
// button is an ink-dark brick; the ghost is a white-outlined slab.
import { docsUrl, GITHUB_URL } from "../../lib/config";
---

<section class="cta">
  <!-- Top / bottom meta rails -->
  <div class="rail top mono">
    <span>CLUB · 2026</span>
    <span>■ Open source · Apache 2.0</span>
    <span>→ ghcr.io/club/club</span>
  </div>

  <div class="wrap">
    <div class="grid">
      <!-- Ink-dark slab -->
      <aside class="slab">
        <div class="slab-corner"></div>
        <div class="slab-k mono">✦ Closing statement</div>
        <div class="slab-num">01</div>
        <div class="slab-tag mono">/ host / own / ship</div>
      </aside>

      <!-- Content -->
      <div class="content">
        <h2 class="h2">
          Host your own <em>pub</em>.
        </h2>
        <p class="lede">
          One container. Your cloud. Your rules.
          Five minutes on a laptop; an afternoon to roll out.
        </p>
        <div class="cta-row">
          <a href={docsUrl("/getting-started/quick-start/")} class="btn-brick">
            Read the quick start
            <span class="arrow">→</span>
          </a>
          <a href={GITHUB_URL} class="btn-slab">
            GitHub
            <span class="arrow up">↗</span>
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="rail bottom mono">
    <span>No tracking</span>
    <span>· Multi-arch Docker</span>
    <span>· Your storage</span>
    <span class="spacer"></span>
    <span>— fin —</span>
  </div>
</section>

<style>
  .cta {
    background: var(--color-stamp); color: #fff;
    border-top: 3px solid var(--color-ink);
    border-bottom: 3px solid var(--color-ink);
    position: relative; overflow: hidden;
  }
  .wrap { max-width: 86rem; margin: 0 auto; padding: 2rem; }
  @media (max-width: 768px) { .wrap { padding: 1.5rem 1.25rem; } }

  .rail {
    display: flex; flex-wrap: wrap; align-items: center; gap: 0.6rem 1.25rem;
    padding: 0.75rem 2rem;
    background: var(--color-ink-dark); color: #EDEDED;
    font-size: 0.68rem; letter-spacing: 0.2em; text-transform: uppercase; font-weight: 600;
  }
  .rail.top { border-bottom: 1px solid var(--color-stamp); }
  .rail.bottom { border-top: 1px solid var(--color-stamp); }
  .rail .spacer { flex: 1; }
  @media (max-width: 768px) { .rail { padding: 0.75rem 1.25rem; gap: 0.4rem 0.8rem; } }

  .grid {
    display: grid; gap: 0;
    grid-template-columns: minmax(0, 0.4fr) minmax(0, 0.6fr);
    align-items: stretch;
    border: 2px solid var(--color-ink);
    background: var(--color-stamp);
  }
  @media (max-width: 900px) { .grid { grid-template-columns: 1fr; } }

  /* Slab */
  .slab {
    position: relative;
    padding: 3rem 2.25rem;
    background: var(--color-ink-dark); color: #EDEDED;
    border-right: 2px solid var(--color-ink);
    display: flex; flex-direction: column; justify-content: space-between;
    min-height: 18rem;
    overflow: hidden;
  }
  @media (max-width: 900px) {
    .slab { border-right: 0; border-bottom: 2px solid var(--color-ink); min-height: auto; }
  }
  .slab-corner {
    position: absolute; right: 0; top: 0;
    width: 0; height: 0;
    border-top: 3rem solid var(--color-stamp);
    border-left: 3rem solid transparent;
  }
  .slab-k {
    font-size: 0.7rem; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--color-stamp); font-weight: 700;
  }
  .slab-num {
    font-family: var(--font-sans); font-weight: 700;
    font-size: clamp(6rem, 14vw, 10rem); letter-spacing: -0.05em;
    line-height: 0.85; color: #EDEDED;
  }
  .slab-tag { font-size: 0.72rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--color-mute-dark); }

  /* Content */
  .content {
    padding: 3rem 2.5rem 2.5rem;
    display: flex; flex-direction: column; justify-content: center;
  }
  @media (max-width: 900px) { .content { padding: 2.25rem 1.75rem; } }

  .h2 {
    font-family: var(--font-sans); font-weight: 700;
    font-size: clamp(2.5rem, 5vw + 0.5rem, 4.5rem);
    letter-spacing: -0.035em; line-height: 0.98;
    margin: 0; color: #fff; max-width: 12ch;
  }
  .h2 em { font-style: italic; font-weight: 580; }

  .lede {
    font-size: 1.05rem; line-height: 1.55;
    color: #FFE4DA; margin: 1.25rem 0 0; max-width: 36rem;
  }

  .cta-row { margin-top: 2rem; display: flex; flex-wrap: wrap; gap: 0.5rem; }

  /* Buttons — hard edges, no border radius */
  .btn-brick, .btn-slab {
    display: inline-flex; align-items: center; gap: 0.5em;
    padding: 0.85em 1.25em;
    font-family: var(--font-sans); font-size: 0.88rem; font-weight: 680;
    letter-spacing: -0.005em;
    border-radius: 0;
    transition: transform 120ms, background 120ms;
  }
  .btn-brick {
    background: var(--color-ink); color: #fff;
    border: 2px solid var(--color-ink);
  }
  .btn-brick:hover { transform: translate(-2px, -2px); box-shadow: 4px 4px 0 0 #fff; }
  .btn-slab {
    background: transparent; color: #fff;
    border: 2px solid #fff;
  }
  .btn-slab:hover { background: #fff; color: var(--color-ink); }
  .arrow { transition: transform 180ms cubic-bezier(.2,.8,.2,1); }
  .arrow.up { display: inline-block; }
  .btn-brick:hover .arrow { transform: translateX(2px); }

  .mono { font-family: var(--font-mono); }
</style>
