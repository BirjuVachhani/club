---
// CTA variant C — "Split with code"
// Asymmetric grid. Copy + CTAs on the left, a dark code card on the
// right showing the one-liner that actually starts the server.
// Feels more actionable than a pure copy CTA.
import { docsUrl, GITHUB_URL } from "../../lib/config";
---

<section class="cta">
  <div class="wrap">
    <div class="grid">
      <div class="copy">
        <div class="eyebrow orange mono">§ Get started</div>
        <h2 class="h2">
          Ready to host your own <span class="accent">pub</span>?
        </h2>
        <p class="lede">
          It's one <span class="ink">docker run</span> away. Point
          your <span class="ink">dart pub</span> at it and keep shipping.
        </p>
        <div class="cta-row">
          <a href={docsUrl("/getting-started/quick-start/")} class="btn btn-primary">
            Read the quick start
            <span class="btn-arrow">→</span>
          </a>
          <a href={GITHUB_URL} class="btn btn-ghost">GitHub</a>
        </div>
        <ul class="chips mono">
          <li>Apache 2.0</li>
          <li class="o">·</li>
          <li>linux/amd64 + arm64</li>
          <li class="o">·</li>
          <li>no telemetry</li>
        </ul>
      </div>

      <figure class="code">
        <header class="code-head">
          <span class="dot"></span><span class="dot"></span><span class="dot"></span>
          <span class="code-title mono">~ · zsh</span>
        </header>
        <pre><code><span class="p">$</span> docker run -p <span class="o">8080:8080</span> \
    -e JWT_SECRET=$SECRET \
    -e BLOB_BACKEND=<span class="o">fs</span> \
    ghcr.io/club/club:<span class="o">latest</span>

<span class="dim">✓ club · listening on :8080</span>
<span class="dim">✓ point dart pub at it</span><span class="cursor">▍</span></code></pre>
      </figure>
    </div>
  </div>
</section>

<style>
  .cta { padding: 6rem 0; background: var(--color-paper-mute); border-top: 1px solid var(--color-border); }
  .wrap { max-width: 84rem; margin: 0 auto; padding: 0 2rem; }
  @media (max-width: 768px) { .wrap { padding: 0 1.25rem; } }

  .grid {
    display: grid; gap: 3rem; align-items: center;
    grid-template-columns: minmax(0, 0.46fr) minmax(0, 0.54fr);
  }
  @media (max-width: 1000px) { .grid { grid-template-columns: 1fr; } }

  .accent, .o { color: var(--color-stamp); }
  .mono { font-family: var(--font-mono); }
  .dim { color: var(--color-mute-dark); }
  .p { color: var(--color-stamp); }
  .ink { color: var(--color-ink); font-family: var(--font-mono); background: var(--color-stamp-soft); padding: 0 0.3em; border-radius: 4px; font-size: 0.92em; }

  .eyebrow { font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; font-weight: 600; color: var(--color-stamp); }
  .h2 {
    font-family: var(--font-sans); font-weight: 700;
    font-size: clamp(2.15rem, 3.5vw + 0.25rem, 3.25rem);
    letter-spacing: -0.03em; line-height: 1.05; margin: 1rem 0 0;
    max-width: 16ch; color: var(--color-ink);
  }
  .lede { font-size: 1.1rem; line-height: 1.55; color: var(--color-mute); margin: 1.25rem 0 0; max-width: 32rem; }
  .cta-row { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.75rem; }

  .chips {
    list-style: none; padding: 0; margin: 1.75rem 0 0;
    display: flex; flex-wrap: wrap; gap: 0.5rem 0.75rem; align-items: baseline;
    font-size: 0.7rem; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--color-mute); font-weight: 600;
  }

  /* Code card */
  .code {
    margin: 0; background: var(--color-ink-dark); color: #EDEDED;
    border: 1px solid var(--color-border-dark); border-radius: 14px; overflow: hidden;
    box-shadow: 0 30px 60px -30px rgba(5,5,5,0.35);
  }
  .code-head {
    display: flex; align-items: center; gap: 0.4rem;
    padding: 0.7rem 0.9rem; border-bottom: 1px solid var(--color-border-dark);
  }
  .dot { width: 10px; height: 10px; border-radius: 999px; background: #3a3a3a; }
  .code-title { margin-left: auto; font-size: 0.65rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-mute-dark); }
  .code pre { margin: 0; padding: 1.25rem; font-family: var(--font-mono); font-size: 0.88rem; line-height: 1.75; color: #EDEDED; overflow-x: auto; }

  .cursor { display: inline-block; width: 0.55em; background: var(--color-stamp); color: transparent; animation: blink 1.1s step-end infinite; }
  @keyframes blink { 0%,50%{opacity:1} 51%,100%{opacity:0} }
</style>
