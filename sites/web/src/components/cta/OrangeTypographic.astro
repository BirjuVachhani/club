---
// CTA variant E5 — "Orange typographic"
// The word "yours" takes over the entire band — huge italic, edge-to-
// edge. Supporting copy and CTAs live in the margin. Confident, almost
// a wordmark poster.
import { docsUrl, GITHUB_URL } from "../../lib/config";
---

<section class="cta">
  <div class="wrap">
    <div class="rail top mono">
      <span>— Ready to host? —</span>
      <span>CLUB / v0.1</span>
    </div>

    <!-- Giant word -->
    <h2 class="word" aria-label="Yours. A private pub.dev you host yourself.">
      <span class="pre">A&nbsp;private&nbsp;pub,</span>
      <em class="big">yours</em>
      <span class="post">— on your infra, your terms.</span>
    </h2>

    <div class="tail">
      <div class="side copy">
        <p>
          One container. Five minutes to see it running.
          Point your <span class="ink">dart&nbsp;pub</span> at it
          and keep shipping.
        </p>
      </div>
      <div class="side actions">
        <a href={docsUrl("/getting-started/quick-start/")} class="btn-ink">
          Read the quick start
          <span class="arrow">→</span>
        </a>
        <a href={GITHUB_URL} class="btn-outline">GitHub ↗</a>
      </div>
    </div>

    <div class="rail bot mono">
      <span>Apache 2.0</span>
      <span class="sep">·</span>
      <span>multi-arch docker</span>
      <span class="sep">·</span>
      <span>no telemetry</span>
    </div>
  </div>
</section>

<style>
  .cta {
    background: var(--color-stamp); color: #fff;
    padding: 4rem 0 3.5rem;
    position: relative; overflow: hidden;
  }
  .wrap { max-width: 90rem; margin: 0 auto; padding: 0 2rem; position: relative; }
  @media (max-width: 768px) { .wrap { padding: 0 1.25rem; } }

  .rail {
    display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between;
    gap: 0.5rem 1rem;
    font-family: var(--font-mono); font-size: 0.7rem;
    letter-spacing: 0.22em; text-transform: uppercase;
    color: #FFE4DA; font-weight: 700;
  }
  .rail.top { padding-bottom: 0.75rem; border-bottom: 1px dashed color-mix(in oklab, #fff 40%, transparent); }
  .rail.bot { padding-top: 0.75rem; border-top: 1px dashed color-mix(in oklab, #fff 40%, transparent); margin-top: 1rem; justify-content: center; }
  .rail.bot .sep { color: #fff; opacity: 0.55; }

  /* Giant word */
  .word {
    margin: 2rem 0 1rem;
    font-family: var(--font-sans); font-weight: 700;
    letter-spacing: -0.045em; line-height: 0.82;
    color: #fff;
    display: flex; flex-direction: column; gap: 0;
  }
  .word .pre, .word .post {
    font-size: clamp(1.05rem, 1.2vw + 0.5rem, 1.35rem);
    font-weight: 600; letter-spacing: 0.02em; color: #FFE4DA;
    line-height: 1.3;
  }
  .word .pre { padding-bottom: 0.35rem; }
  .word .post { padding-top: 0.35rem; }
  .word .big {
    font-style: italic; font-weight: 580;
    color: var(--color-ink);
    font-size: clamp(6rem, 18vw, 17rem);
    letter-spacing: -0.065em;
    padding: 0.04em 0;
  }
  @media (max-width: 600px) {
    .word .big { font-size: clamp(4.5rem, 24vw, 8rem); }
  }

  /* Tail row */
  .tail {
    margin-top: 1rem;
    display: grid; gap: 2rem;
    grid-template-columns: minmax(0, 0.55fr) minmax(0, 0.45fr);
    align-items: start;
  }
  @media (max-width: 800px) { .tail { grid-template-columns: 1fr; } }

  .copy p {
    margin: 0; max-width: 44ch;
    font-size: 1.05rem; line-height: 1.55; color: #fff;
  }
  .ink { font-family: var(--font-mono); background: rgba(0,0,0,0.18); padding: 0 0.3em; border-radius: 4px; font-size: 0.92em; color: #fff; }

  .actions { display: flex; flex-wrap: wrap; gap: 0.6rem; justify-content: flex-end; }
  @media (max-width: 800px) { .actions { justify-content: flex-start; } }

  .btn-ink, .btn-outline {
    display: inline-flex; align-items: center; gap: 0.5em;
    padding: 0.8em 1.25em; border-radius: 0.625rem;
    font-family: var(--font-sans); font-size: 0.9rem; font-weight: 640;
    transition: background 150ms, transform 150ms;
  }
  .btn-ink { background: var(--color-ink); color: #fff; border: 1px solid var(--color-ink); }
  .btn-ink:hover { transform: translateY(-1px); box-shadow: 0 10px 24px -12px rgba(0,0,0,0.4); }
  .btn-outline { background: transparent; color: #fff; border: 1px solid color-mix(in oklab, #fff 50%, transparent); }
  .btn-outline:hover { background: color-mix(in oklab, #fff 12%, transparent); border-color: #fff; }
  .arrow { transition: transform 180ms cubic-bezier(.2,.8,.2,1); }
  .btn-ink:hover .arrow { transform: translateX(2px); }

  .mono { font-family: var(--font-mono); }
</style>
